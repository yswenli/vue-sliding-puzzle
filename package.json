{
  "name": "vue-sliding-puzzle",
  "version": "3.263.318",
  "description": "基于 Vue 3 的滑动拼图验证码组件，支持干扰图、时间判定等安全特性",
  "keywords": [
    "vue",
    "vue3",
    "sliding-puzzle",
    "captcha",
    "verification",
    "slider-captcha",
    "puzzle-captcha",
    "vue-puzzle-captcha",
    "security",
    "anti-bot",
    "人机验证",
    "验证码",
    "滑动验证",
    "拼图验证",
    "component",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "module": "./dist/vue-sliding-puzzle.es.js",
  "main": "./dist/vue-sliding-puzzle.umd.js",
  "typings": "./dist/main.d.ts",
  "exports": {
    ".": {
      "import": "./dist/vue-sliding-puzzle.es.js",
      "require": "./dist/vue-sliding-puzzle.umd.js"
    },
    "./css": {
      "import": "./dist/main.css",
      "require": "./dist/main.css"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@types/node": "^18.15.5",
    "@vitejs/plugin-vue": "^4.1.0",
    "less": "^4.1.3",
    "typescript": "^5.6.3",
    "vite": "^4.2.1",
    "vite-plugin-dts": "^2.1.0",
    "vue": "^3.2.47",
    "vue-tsc": "^2.0.14"
  }
}
